# 代号4：每批导出链接打开后，等待多少秒再检查下载文件是否齐备。
MODE4_BATCH_WAIT_SECONDS=60

# 代号4：每批打开多少个导出链接。
MODE4_BATCH_SIZE=5

# 代号4：每批下载不完整时，最多自动重试多少次。
MODE4_RETRY_LIMIT=3

# 代号4：每次打开导出链接后，检查缺失文件的机会次数。
MODE4_MISSING_CHECK_CHANCES=10

# 代号4：每次检查缺失文件之间等待多少秒。
MODE4_CHECK_INTERVAL_SECONDS=2

# 代号4 EPIN：订单列表每次点击“加载更多”后，继续下一次点击前等待多少秒。
MODE4_EPIN_ORDER_LOAD_INTERVAL_SECONDS=3
