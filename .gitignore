# Python virtual environments
venv/
.venv/
.vscode/
env/
ENV/

# Python cache and test artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

# PyInstaller build artifacts
build/
dist/
dist_mac/
*.manifest
*.pyz

# Local logs and temporary files
*.log
*.tmp
*.temp
Thumbs.db
.DS_Store

# Excel temporary lock files
~$*

# Runtime input/output data
data/input/*
data/output/*
!data/input/
!data/input/raw/
!data/input/.gitkeep
!data/input/raw/.gitkeep
!data/output/
!data/output/.gitkeep

# Bank/export files are usually business data.
# Keep the template workbook versioned, but ignore ad-hoc spreadsheets elsewhere.
**/*.xlsx
**/*.xls
**/*.csv

**/**.bat
**/**.spec
**/**.ps1

